---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const dispatches = await getCollection('dispatches');
  return dispatches.map((d) => ({ params: { slug: d.id }, props: { d } }));
}

const { d } = Astro.props;
const { Content } = await render(d);

const fmt = (date: Date) =>
  date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
---

<Layout title={`${d.data.title} · The Hedge`}>
  <header class="mb-12">
    <p class="text-xs uppercase tracking-widest text-stone-500">
      <a href="/dispatches/" class="underline decoration-stone-300">Dispatch</a>
      <span class="mx-2">·</span>
      {fmt(d.data.date)}
    </p>
    <h1 class="text-3xl md:text-4xl font-medium tracking-tight mt-3">{d.data.title}</h1>
    {d.data.weather && <p class="text-stone-600 mt-4 text-sm">{d.data.weather}</p>}
  </header>

  <article class="prose prose-stone prose-lg max-w-none prose-headings:font-medium prose-headings:tracking-tight">
    <Content />
  </article>

  {
    d.data.generated && (
      <p class="mt-12 text-xs text-stone-400 italic border-t border-stone-200 pt-4">
        Auto-generated dispatch{d.data.model ? ` (${d.data.model})` : ''}, grounded in real
        weather, phenology, and almanac data. Experimental.
      </p>
    )
  }

  <nav class="mt-12 pt-6 border-t border-stone-300 text-sm text-stone-600 flex flex-wrap gap-x-4 gap-y-2">
    <a href="/" class="underline">Home</a>
    <a href="/dispatches/" class="underline">All dispatches</a>
    <a href="/issues/" class="underline">Issues</a>
  </nav>
</Layout>
