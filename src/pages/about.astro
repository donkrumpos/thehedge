---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About · The Hedge">
  <header class="mb-12 border-b border-stone-300 pb-6">
    <h1 class="text-3xl font-medium tracking-tight">
      <a href="/" class="no-underline">The Hedge</a>
    </h1>
  </header>

  <article class="prose prose-stone max-w-none">
    <p>
      Weekly reports from the hedge — the literal edge between cultivated and wild, and the place from
      which observations carry back.
    </p>
    <p>
      Written by Don Krumpos from a brick building in Algoma, Wisconsin. One year, twelve monthly
      clusters, forty-eight pieces. October to October.
    </p>
    <p>
      Quiet by design. No tracking, no analytics, no engagement loops, no popups. RSS is the canonical
      channel. Email subscription may arrive later if the work earns it.
    </p>
    <p>
      A printed riso edition collects the essays seasonally. The web is the archive; the print is what
      travels.
    </p>
  </article>

  <nav class="mt-16 pt-6 border-t border-stone-300 text-sm text-stone-600 flex flex-wrap gap-x-4 gap-y-2">
    <a href="/" class="underline">Home</a>
    <a href="/issues/" class="underline">All issues</a>
    <a href="/rss.xml" class="underline">RSS</a>
  </nav>
</Layout>
