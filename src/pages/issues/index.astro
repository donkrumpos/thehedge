---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const issues = await getCollection('issues');
const sorted = issues.sort((a, b) => a.data.number - b.data.number);

const byCluster = sorted.reduce<Record<string, CollectionEntry<'issues'>[]>>((acc, issue) => {
  const key = `${issue.data.month} — ${issue.data.cluster}`;
  (acc[key] = acc[key] ?? []).push(issue);
  return acc;
}, {});
---

<Layout title="All issues · The Hedge">
  <header class="mb-12 border-b border-stone-300 pb-6">
    <h1 class="text-3xl font-medium tracking-tight">
      <a href="/" class="no-underline">The Hedge</a>
    </h1>
    <p class="text-stone-600 mt-2 italic">All issues, by month-cluster.</p>
  </header>

  {
    Object.entries(byCluster).length === 0 ? (
      <p class="text-stone-500 italic">No issues yet.</p>
    ) : (
      Object.entries(byCluster).map(([cluster, items]) => (
        <section class="mb-10">
          <h2 class="text-xs uppercase tracking-widest text-stone-500 mb-3">{cluster}</h2>
          <ul class="space-y-2">
            {items.map((issue) => (
              <li class="flex gap-3">
                <span class="text-stone-400 tabular-nums w-6 text-right">{issue.data.number}.</span>
                {issue.data.status === 'published' ? (
                  <a href={`/issues/${issue.id}/`} class="underline decoration-stone-300 hover:decoration-stone-700">
                    {issue.data.title}
                  </a>
                ) : (
                  <span class="text-stone-500">
                    {issue.data.title}
                    <span class="text-xs italic ml-2">({issue.data.status})</span>
                  </span>
                )}
              </li>
            ))}
          </ul>
        </section>
      ))
    )
  }

  <nav class="mt-16 pt-6 border-t border-stone-300 text-sm text-stone-600 flex flex-wrap gap-x-4 gap-y-2">
    <a href="/" class="underline">Home</a>
    <a href="/about/" class="underline">About</a>
    <a href="/rss.xml" class="underline">RSS</a>
  </nav>
</Layout>
