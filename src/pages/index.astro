---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const issues = await getCollection('issues');
const published = issues
  .filter((i) => i.data.status === 'published')
  .sort(
    (a, b) =>
      (b.data.published?.getTime() ?? 0) - (a.data.published?.getTime() ?? 0),
  );
const latest = published[0];
---

<Layout title="The Hedge">
  <header class="mb-16 border-b border-stone-300 pb-8">
    <h1 class="text-4xl font-medium tracking-tight">The Hedge</h1>
    <p class="text-stone-600 mt-3 italic">Weekly reports from the edge of village.</p>
  </header>

  {
    latest ? (
      <article>
        <p class="text-sm text-stone-500 uppercase tracking-wide">
          Issue {latest.data.number} · {latest.data.cluster}
        </p>
        <h2 class="text-2xl mt-3">
          <a href={`/issues/${latest.id}/`} class="underline decoration-stone-300 hover:decoration-stone-700">
            {latest.data.title}
          </a>
        </h2>
        {latest.data.subtitle && <p class="text-stone-600 mt-3 italic">{latest.data.subtitle}</p>}
      </article>
    ) : (
      <p class="text-stone-500 italic">No issues published yet. The first piece is being written.</p>
    )
  }

  <nav class="mt-20 pt-6 border-t border-stone-300 text-sm text-stone-600 flex flex-wrap gap-x-4 gap-y-2">
    <a href="/issues/" class="underline">All issues</a>
    <a href="/about/" class="underline">About</a>
    <a href="/rss.xml" class="underline">RSS</a>
  </nav>
</Layout>
